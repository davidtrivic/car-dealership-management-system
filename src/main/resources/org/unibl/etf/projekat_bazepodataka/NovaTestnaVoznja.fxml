<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.unibl.etf.projekat_bazepodataka.ui.NovaTestnaVoznjaController"
      spacing="0" style="-fx-padding: 20;">

    <Label text="Zakaži testnu vožnju" styleClass="title-3"/>
    <Separator style="-fx-padding: 5 0 10 0;"/>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="12" style="-fx-padding: 5 10 5 0;">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Vozilo:" prefWidth="150"/>
                <ComboBox fx:id="comboVozilo" prefWidth="280" promptText="Odaberite vozilo"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Kupac:" prefWidth="150"/>
                <ComboBox fx:id="comboKupac" prefWidth="280" promptText="Odaberite kupca"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Agent:" prefWidth="150"/>
                <ComboBox fx:id="comboAgent" prefWidth="280" promptText="Odaberite agenta"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Datum vožnje:" prefWidth="150"/>
                <DatePicker fx:id="datumVoznje" prefWidth="280"/>
            </HBox>

        </VBox>
    </ScrollPane>

    <Separator style="-fx-padding: 10 0 0 0;"/>
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Odustani" onAction="#odustani"/>
        <Button text="Zakaži" styleClass="accent" onAction="#sacuvaj"/>
    </HBox>

</VBox>